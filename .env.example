# ==================================================
# SUPABASE CONFIGURATION
# ==================================================
# Switch between LOCAL and CLOUD by commenting/uncommenting



# Stripe Configuration
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}



                                             


# Site Configuration
SITE_URL=${SITE_URL}
NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL}


# Rate Limiting
RATE_LIMIT_PER_MINUTE=${RATE_LIMIT_PER_MINUTE}
RATE_LIMIT_PER_HOUR=${RATE_LIMIT_PER_HOUR}


# AWS API Gateway (Backend Services)
# Get this URL after deploying dink-house-db-aws with: serverless info --stage dev
NEXT_PUBLIC_AWS_API_URL=${NEXT_PUBLIC_AWS_API_URL}
AWS_API_URL=${AWS_API_URL}


# AWS CloudFront CDN (Media Storage)
NEXT_PUBLIC_CLOUDFRONT_URL=${NEXT_PUBLIC_CLOUDFRONT_URL}
NEXT_PUBLIC_MEDIA_BUCKET=${NEXT_PUBLIC_MEDIA_BUCKET}


# Database Configuration (AWS RDS)
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_SSL=${DB_SSL}
