# Supabase Configuration
# Copy this file to .env.local and add your actual keys

# Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key — safe to expose in the browser (Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — server-only; use in API routes (Settings → API → service_role)
# Required for /api/stripe/create-checkout and /api/stripe/webhook
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Optional: Email configuration for production
CONTACT_EMAIL=contact@dinkhousepb.com
FROM_EMAIL=noreply@dinkhousepb.com

# Optional: MailPit configuration for local email testing
MAILPIT_HOST=localhost
MAILPIT_SMTP_PORT=1025

# Cloudflare Turnstile Configuration (replaces reCAPTCHA)
# Get your keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here